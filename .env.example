# ── People Counter — environment example ─────────────────────────────
# Copy to `.env` and fill real values. NEVER commit `.env`.

# ── Backend ──
PORT=4100
TZ=Asia/Bangkok

# Hour of day (0-23, server TZ) at which daily occupancy resets. 0 = midnight.
OCCUPANCY_RESET_HOUR=0

# ── PostgreSQL ──
# When running via docker-compose the host is the `postgres` service name.
DATABASE_URL=postgres://people:CHANGE_ME@postgres:5432/peoplecounter
# Used only by docker-compose to init the postgres container:
POSTGRES_USER=people
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=peoplecounter

# ── Cameras (Dahua RTSP → MediaMTX HLS) ──
# RTSP credentials are placeholders — put real values only in `.env`.
# subtype=1 = sub stream (smaller, for web live view).
CAM_LEFT_NAME=AIDC Tech
CAM_LEFT_RTSP=rtsp://user:pass@10.0.100.51:554/cam/realmonitor?channel=1&subtype=1
CAM_LEFT_HLS=http://10.0.100.46:8888/left/index.m3u8

CAM_RIGHT_NAME=AIDC
CAM_RIGHT_RTSP=rtsp://user:pass@10.0.100.52:554/cam/realmonitor?channel=1&subtype=1
CAM_RIGHT_HLS=http://10.0.100.46:8888/right/index.m3u8
