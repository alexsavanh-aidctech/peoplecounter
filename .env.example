# ── People Counter — environment example ─────────────────────────────
# Copy to `.env` and fill REAL values there. NEVER put real values here.
# `.env` is gitignored; this file (committed) must stay placeholders only.

# ── Backend / Web ──
# Backend port INSIDE the compose network (nginx proxies /api here; keep in sync
# with frontend/nginx.conf's proxy_pass). Also the host-published port.
PORT=4102
# Port the dashboard (nginx frontend) is published on.
WEB_PORT=8080
TZ=Asia/Bangkok
# Hour of day (0-23, server TZ) at which daily occupancy resets. 0 = midnight.
OCCUPANCY_RESET_HOUR=0

# ── PostgreSQL ──
# When running via docker-compose the host is the `postgres` service name.
DATABASE_URL=postgres://people:CHANGE_ME@postgres:5432/peoplecounter
POSTGRES_USER=people
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=peoplecounter

# ── Cameras (Dahua) — real IP/user/pass go in .env, NOT here ──
# Left gate = AIDC Tech
CAM_LEFT_NAME=AIDC Tech
CAM_LEFT_IP=192.168.x.x
CAM_LEFT_USER=admin
CAM_LEFT_PASS=changeme
# Right gate = AIDC
CAM_RIGHT_NAME=AIDC
CAM_RIGHT_IP=192.168.x.x
CAM_RIGHT_USER=admin
CAM_RIGHT_PASS=changeme

# ── MediaMTX / HLS ──
# MediaMTX builds each RTSP source from CAM_*_IP/USER/PASS using Dahua's
# subtype=1 (sub stream — smaller, for web live view). Frontend plays
# <MEDIAMTX_HLS_BASE>/<gate>/index.m3u8 (URL comes from /api/live-config at
# runtime — changing this needs only a backend recreate, no frontend rebuild).
#   dev  : http://localhost:8888          (browser → MediaMTX direct)
#   prod : https://<domain>/hls           (browser → nginx /hls/ → mediamtx:8888)
# On an HTTPS domain you MUST use the /hls path (not http://IP:8888) or the
# browser blocks it as Mixed Content. The /hls/ route lives in frontend/nginx.conf.
MEDIAMTX_HLS_BASE=http://localhost:8888
# Set to 1 to transcode a H.265/HEVC camera to H.264 for browser HLS (CPU heavy).
CAM_LEFT_TRANSCODE=0
CAM_RIGHT_TRANSCODE=0

# ── videoStatServer poller (Phase 4B) ──
# How often to pull People-Counting (NumberStat) counts from each camera.
POLL_INTERVAL_SECONDS=10
# RPC channel per camera (direct camera = 0) and NumberStat rule AreaID.
CAM_LEFT_RPC_CHANNEL=0
CAM_LEFT_AREA_ID=1
CAM_RIGHT_RPC_CHANNEL=0
CAM_RIGHT_AREA_ID=1
# Set to 1 if the door's count line is oriented so the device's "Entered" is
# actually people LEAVING — swaps Entered<->Exited into our in/out. Verify vs OSD.
CAM_LEFT_SWAP_INOUT=0
CAM_RIGHT_SWAP_INOUT=0
